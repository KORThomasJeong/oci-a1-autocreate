# ===========================================================================
#  설정 파일 — 이 파일을 복사해 .env 로 만들고 값을 채우세요. (setup.sh 가 자동 복사)
# ===========================================================================

# ---- 텔레그램 알림 (필수) -------------------------------------------------
# 1) 텔레그램에서 @BotFather 검색 -> /newbot -> 봇 이름 지정 -> 토큰 발급
# 2) 만든 봇과 대화방을 연 뒤 아무 메시지나 전송
# 3) 아래 명령으로 chat_id 확인:
#      curl "https://api.telegram.org/bot<여기에_토큰>/getUpdates"
#    결과 JSON 의 "chat":{"id": 숫자 } 가 chat_id 입니다.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ---- 인스턴스 사양 (선택: 비우면 terraform 기본값 사용) -------------------
# 무료 한도 합계: 4 OCPU / 24GB RAM / 블록스토리지 200GB
# 용량(capacity) 확보가 계속 안 되면 사양을 낮춰보세요 (예: 1 OCPU / 6GB).
TF_VAR_ocpus="2"
TF_VAR_memory_in_gbs="12"
TF_VAR_boot_volume_size_in_gbs="50"
TF_VAR_instance_display_name="oci-a1-auto"

# ---- OCI 리소스 (필수) ----------------------------------------------------
# 자신의 계정 값으로 반드시 채우세요. OCI 콘솔 또는 CLI 로 확인:
#   oci iam compartment list
#   oci iam availability-domain list
#   oci network vcn list  --compartment-id <컴파트먼트>
#   oci network subnet list --compartment-id <컴파트먼트> --vcn-id <VCN>
# region 은 비우면 ap-chuncheon-1 기본값 사용.
# TF_VAR_region="ap-chuncheon-1"
TF_VAR_compartment_ocid=""      # 예: ocid1.tenancy.oc1..xxxx (루트면 테넌시 OCID)
TF_VAR_availability_domain=""   # 예: WZid:AP-CHUNCHEON-1-AD-1
TF_VAR_vcn_id=""                # 예: ocid1.vcn.oc1.ap-chuncheon-1.xxxx
TF_VAR_subnet_id=""             # 예: ocid1.subnet.oc1.ap-chuncheon-1.xxxx
